{
  "name": "lumenpulse",
  "private": true,
  "scripts": {
    "lint": "node scripts/lint.mjs",
    "lint:backend": "npm run lint --prefix apps/backend",
    "lint:webapp": "npm run lint --prefix apps/webapp",
    "lint:mobile": "npm run lint --prefix apps/mobile",
    "install:apps": "npm install --prefix apps/backend && npm install --prefix apps/webapp && npm install --prefix apps/mobile",
    "test": "npm run test --prefix apps/backend && npm run test --prefix apps/webapp",
    "dev:backend": "npm run start:dev --prefix apps/backend",
    "dev:webapp": "npm run dev --prefix apps/webapp"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^2.9.6"
  }
}
