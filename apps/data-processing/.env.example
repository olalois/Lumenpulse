# Data Processing Service Configuration

# Run the analyzer immediately on service startup (useful for testing)
# Set to 'true' to run immediately, 'false' or omit to wait for first scheduled run
RUN_IMMEDIATELY=false

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Data retention (days) - old analytics older than this will be cleaned up
DATA_RETENTION_DAYS=30

# PostgreSQL Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lumenpulse
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lumenpulse
DB_USER=postgres
DB_PASSWORD=postgres

# Optional: API keys for enhanced features
# COINGECKO_API_KEY=your_key_here
# NEWS_API_KEY=your_key_here

CRYPTOCOMPARE_API_KEY=your_key_here
NEWSAPI_API_KEY=your_key_here

# Social Media API Keys (for sentiment analysis)
# Twitter/X API Bearer Token - Get from https://developer.twitter.com/
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Telegram Alert Bot Configuration
# Create a bot via @BotFather on Telegram to get your token
# Add the bot to your channel as admin and get the channel ID
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=your_channel_id_here
ALERT_WEBHOOK_URL=your_webhook_url_here
ALERT_MIN_SEVERITY=0.5

# Redis Cache Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL_SECONDS=86400 # 24 hours

# API Security Configuration
API_KEY=X-API-Key-Header-Value-Change-In-Production
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_STRICT=10/minute
RATE_LIMIT_ENABLED=true

# Network Configuration (mainnet or testnet)
NETWORK=mainnet

# Round Anomaly Detection Configuration (#874)
# Thresholds for detecting suspicious allocation patterns in quadratic funding rounds
# Set to empty to use defaults (mainnet: 0.7, testnet: 0.84)
ROUND_CONCENTRATION_THRESHOLD=
# Gini coefficient threshold for inequality detection (mainnet: 0.6, testnet: 0.72)
ROUND_GINI_THRESHOLD=
# Maximum allowed ratio from single contributor (mainnet: 0.5, testnet: 0.6)
ROUND_SINGLE_CONTRIBUTION_THRESHOLD=
# Minimum unique contributors per project (mainnet: 3, testnet: 2)
ROUND_MIN_CONTRIBUTORS=
# Time window in hours for timing cluster analysis
ROUND_TIMING_WINDOW_HOURS=1
# Maximum allowed ratio in time window (mainnet: 0.8, testnet: 0.96)
ROUND_TIMING_THRESHOLD=